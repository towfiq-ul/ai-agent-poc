# =============================================================
# RAG Pipeline — environment configuration
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================


# ── LLM provider ─────────────────────────────────────────────
# "ollama" = fully local, no API key needed
# "groq"   = free cloud API, much faster, requires GROQ_API_KEY
LLM_PROVIDER=ollama

# Timeout in seconds for LLM inference calls (increase for large local models)
LLM_TIMEOUT_SECONDS=180


# ── Option A: Ollama (local) ──────────────────────────────────
# Install Ollama: https://ollama.com
# With docker-compose --profile ollama, set OLLAMA_BASE_URL to the service name.
# Without Docker, Ollama typically runs on localhost:11434.
AI_AGENT_MODEL=llama3.2
OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_BASE_URL=http://localhost:11434   # ← use this for local dev without Docker


# ── Option B: Groq (free cloud) ──────────────────────────────
# Get a free key: https://console.groq.com
# Recommended models (free tier):
#   llama-3.1-8b-instant     ← fastest
#   llama-3.3-70b-versatile  ← smartest
#   mixtral-8x7b-32768       ← large context window
# LLM_PROVIDER=groq
# AI_AGENT_MODEL=llama-3.1-8b-instant
# GROQ_API_KEY=


# ── Embeddings ────────────────────────────────────────────────
# Runs locally via sentence-transformers. No API key needed.
# Model is downloaded from HuggingFace on first run and cached.
# all-MiniLM-L6-v2   → 384-dim, fast, good quality  (default)
# all-mpnet-base-v2  → 768-dim, slower, higher quality
EMBEDDING_MODEL=all-MiniLM-L6-v2


# ── Django ────────────────────────────────────────────────────
# Generate a real secret key for production:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-production-use-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1 frontend 0.0.0.0
