# --- Google Gemini (embeddings) ---
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
AI_AGENT_MODEL=gemini-3.1-flash-lite
GEMINI_API_KEY=

# --- LanceDB storage path (overridden by docker-compose to /data/lancedb) ---
# Leave unset when running locally; defaults to /data/lancedb.
# LANCEDB_PATH=/data/lancedb
